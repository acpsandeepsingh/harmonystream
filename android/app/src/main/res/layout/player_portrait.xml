<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/player_surface_modern"
    android:paddingStart="14dp"
    android:paddingTop="10dp"
    android:paddingEnd="14dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp">

        <TextView
            android:id="@+id/timeCurrent"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0:00"
            android:textColor="#B0B7C8"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressDrawable="@drawable/seek_progress"
            android:thumb="@drawable/seek_thumb_glow" />

        <TextView
            android:id="@+id/timeDuration"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#B0B7C8"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="4dp">

        <ImageView
            android:id="@+id/thumb"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/player_button_bg"
            android:contentDescription="@string/app_name"
            android:padding="3dp"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Title"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Artist"
                android:textColor="#B0B7C8"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingTop="4dp">

        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="116dp"
            android:layout_gravity="center_vertical">

            <LinearLayout
                android:id="@+id/volumePopupContainer"
                android:layout_width="40dp"
                android:layout_height="88dp"
                android:layout_gravity="top|center_horizontal"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <SeekBar
                    android:id="@+id/volumeBar"
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:progress="100"
                    android:progressDrawable="@drawable/seek_progress"
                    android:rotation="-90"
                    android:thumb="@drawable/seek_thumb_glow" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnVolume"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@drawable/player_button_bg"
                android:contentDescription="Volume"
                android:padding="9dp"
                android:src="@drawable/ic_volume_up"
                android:tint="#FFFFFF" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/player_button_bg"
                android:contentDescription="Previous"
                android:padding="12dp"
                android:src="@drawable/ic_skip_previous"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnPlay"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/player_button_bg_active"
                android:contentDescription="Play"
                android:padding="14dp"
                android:src="@drawable/ic_play_arrow"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/player_button_bg"
                android:contentDescription="Next"
                android:padding="12dp"
                android:src="@drawable/ic_skip_next"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnMode"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/player_button_bg"
            android:contentDescription="Mode"
            android:padding="10dp"
            android:src="@drawable/ic_videocam"
            android:tint="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
